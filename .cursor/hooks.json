{
  "version": 1,
  "hooks": {
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/protect-sensitive-reads.sh",
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/protect-sensitive-writes.sh",
        "matcher": "Write|StrReplace|Delete",
        "failClosed": false
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/protect-destructive-shell.sh",
        "failClosed": true
      }
    ]
  }
}
